# Copy this file to .env.local and fill in your values.
# None of these are required — the app runs fine without them.
# Without integration, new leads are saved to data/leads.json and logged to the console.

# ── WhatsApp / WATI notification (optional) ─────────────────────────────────
# WATI (WhatsApp Team Inbox) — takes priority over WHATSAPP_WEBHOOK_URL.
WATI_API_URL=https://live-server-XXXXX.wati.io
WATI_API_KEY=
WATI_NOTIFICATION_PHONE=994XXXXXXXXXX

# Generic webhook (Make.com, n8n, custom) — receives { text, lead } JSON.
WHATSAPP_WEBHOOK_URL=
